{
	"schemaVersion": 1,
	"id": "compassion-hud",
	"version": "${version}",
	"name": "Compassion HUD",
	"description": "Compassion HUD adds a compass and coordinate readout to the top of your screen",
	"authors": [
		"uberpookie"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/compassion-hud",
		"sources": "https://github.com/Guido-Huijsmans/Compassion_HUD/issues"
	},
	"license": "MIT",
	"icon": "assets/compassion-hud/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "uberpookie.compassion.CompassionHUD",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "uberpookie.compassion.CompassionHUDClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			{ "value": "uberpookie.compassion.CompassionHUDClient", "adapter": "kotlin" }
		],
		"fabric-datagen": [
			{
				"value": "uberpookie.compassion.CompassionHUDDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"compassion-hud.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.1",
		"minecraft": ">=26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"yet_another_config_lib_v3": ">=3.9.3"
	}
}