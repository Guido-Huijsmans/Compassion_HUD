{
	"schemaVersion": 1,
	"id": "compassion-hud",
	"version": "${version}",
	"name": "Compassion HUD",
	"description": "Adds a compass HUD to the top of the screen",
	"authors": [
		"uberpookie"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/compassion-hud/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "uberpookie.compassion.CompassionHUD",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "uberpookie.compassion.CompassionHUDDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"compassion-hud.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}